# ── Atlas environment ──────────────────────────────────────────────
# The app boots and is fully playable (solo, demo panoramas) with NONE of
# these set. Each integration lights up as soon as its keys are present.

# Google Maps — real Street View + JS API.
# Create a key at https://console.cloud.google.com with billing enabled and
# the "Maps JavaScript API" enabled. Restrict the BROWSER key by HTTP referrer.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# Optional server key (HTTP referrer-free) for server-side pano metadata lookups.
GOOGLE_MAPS_SERVER_KEY=

# Convex — realtime backend + database (required for multiplayer, profiles,
# leaderboards, friends, saved stats). Run `npx convex dev` to provision.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Clerk — authentication (required for accounts + everything that persists).
# Keys from https://dashboard.clerk.com. In Convex, add a JWT template named
# "convex" and set CLERK_JWT_ISSUER_DOMAIN in the Convex dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
